ZSCALER_ROOT_CA=/etc/ssl/certs/zscaler-root-ca.pem
SSL_CERT_FILE=${ZSCALER_ROOT_CA}
CURL_CA_BUNDLE=${ZSCALER_ROOT_CA}
NODE_EXTRA_CA_CERTS=${ZSCALER_ROOT_CA}
REQUESTS_CA_BUNDLE=${ZSCALER_ROOT_CA}
GIT_SSL_CAINFO=${ZSCALER_ROOT_CA}

export SSL_CERT_FILE
export CURL_CA_BUNDLE
export NODE_EXTRA_CA_CERTS
export REQUESTS_CA_BUNDLE
export GIT_SSL_CAINFO
